{{- $primary := "Firefox" -}}
{{- $secondary := "Google Chrome" -}}
{{- if hasKey . "browser_primary"   }}{{ $primary   = .browser_primary   }}{{ end -}}
{{- if hasKey . "browser_secondary" }}{{ $secondary = .browser_secondary }}{{ end -}}
# AeroSpace — i3-like tiling WM. Alt acts as "Super" to mirror the Omarchy/hypr
# muscle memory; it is also AeroSpace's own default modifier and, unlike Cmd,
# carries no native macOS shortcuts to clash with. Only non-default options are
# set; omitted keys keep AeroSpace defaults. Tab is left unbound so AltTab keeps
# ⌥Tab. Validate edits with: aerospace reload-config --dry-run

start-at-login = true

# Native ⌘H hides an app, which yanks its window out of the tiler and leaves a
# hole in the layout; auto-unhiding pulls it back so tiling stays consistent
# (AeroSpace default for this is false).
automatically-unhide-macos-hidden-apps = true

# Launch JankyBorders (the `borders` daemon) at startup so the focused window
# gets a Nord frost-blue→white border — AeroSpace draws no decorations itself.
# The gradient is double-quoted so bash does not read its parens as a subshell.
after-startup-command = ['exec-and-forget borders active_color="gradient(top_left=0xff84b0c8,bottom_right=0xffeceff4)" inactive_color=0x00000000 width=5.0 style=round hidpi=on']

[gaps]
inner.horizontal = 6
inner.vertical = 6
outer.left = 6
outer.right = 6
outer.top = 6
outer.bottom = 6

# Static workspace->monitor pins (row-major pairs), unified with hypr's
# workspaces.conf. Roles not ports, so it survives dock/undock: 'main' tracks
# the macOS Main display, 'built-in' the laptop panel. 3&4 pin to the secondary
# external only when monitor_secondary is set in the local [data]; else omitted.
# AeroSpace's 'secondary' keyword is avoided (valid only with exactly 2 monitors).
[workspace-to-monitor-force-assignment]
1 = 'main'
2 = 'main'
{{ if hasKey . "monitor_secondary" -}}
3 = '{{ .monitor_secondary }}'
4 = '{{ .monitor_secondary }}'
{{ end -}}
5 = 'built-in'
6 = 'built-in'

[mode.main.binding]

# Window management. Fullscreen is on alt-semicolon, not alt-f — bare alt-f is
# left free so EurKEY's AltGr+f (right Alt) composes; semicolon's AltGr is unused.
alt-w = 'close'
alt-semicolon = 'fullscreen'
alt-slash = 'layout tiles horizontal vertical'
alt-minus = 'resize smart -50'
alt-equal = 'resize smart +50'

# Focus / move, vi-style — matches hypr bindings.conf (SUPER / SUPER+SHIFT H/J/K/L)
alt-h = 'focus left'
alt-j = 'focus down'
alt-k = 'focus up'
alt-l = 'focus right'
alt-shift-h = 'move left'
alt-shift-j = 'move down'
alt-shift-k = 'move up'
alt-shift-l = 'move right'

# Workspaces 1-6 (switch; shift = move window there and follow)
alt-1 = 'workspace 1'
alt-2 = 'workspace 2'
alt-3 = 'workspace 3'
alt-4 = 'workspace 4'
alt-5 = 'workspace 5'
alt-6 = 'workspace 6'
alt-shift-1 = ['move-node-to-workspace 1', 'workspace 1']
alt-shift-2 = ['move-node-to-workspace 2', 'workspace 2']
alt-shift-3 = ['move-node-to-workspace 3', 'workspace 3']
alt-shift-4 = ['move-node-to-workspace 4', 'workspace 4']
alt-shift-5 = ['move-node-to-workspace 5', 'workspace 5']
alt-shift-6 = ['move-node-to-workspace 6', 'workspace 6']

# New terminal window in the *existing* Ghostty instance, via Ghostty 1.3+
# native AppleScript. `open -n -a Ghostty` was wrong: -n spawns a second app
# instance (extra dock icon), and macOS state restoration rebuilt the old
# split layout inside it. `new window` reuses the running app, fresh window.
alt-enter = '''exec-and-forget osascript -e 'tell application "Ghostty" to new window' '''

# App launchers — open -a is focus-or-launch. Mirrors hypr SUPER+SHIFT+<key>.
# Primary/secondary browser are per-machine: defaults are Firefox / Chrome;
# override browser_primary / browser_secondary in the local chezmoi [data].
alt-shift-enter = 'exec-and-forget open -a "{{ $primary }}"'
alt-shift-b = 'exec-and-forget open -a "{{ $primary }}"'
alt-shift-cmd-b = 'exec-and-forget open -a "{{ $secondary }}"'
alt-shift-o = 'exec-and-forget open -a Obsidian'
alt-shift-f = 'exec-and-forget open -a Finder'
alt-shift-t = 'exec-and-forget open -a "Activity Monitor"'

# Like alt-enter but opens the fresh Ghostty window straight into nvim. Same
# reason for AppleScript over `open -n`: reuse the instance, skip restoration.
alt-shift-n = '''exec-and-forget osascript -e 'tell application "Ghostty" to new window with configuration {command:"nvim"}' '''

# Web apps as chromeless Chrome PWA windows. The Chrome binary is invoked
# directly because `open --args` is ignored when Chrome is already running.
alt-shift-a = '''exec-and-forget "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" --app=https://chatgpt.com'''
alt-shift-e = '''exec-and-forget "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" --app=https://mail.google.com/mail/'''
alt-shift-c = '''exec-and-forget "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" --app=https://calendar.google.com/calendar/u/0/r'''
alt-shift-y = '''exec-and-forget "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" --app=https://youtube.com'''

# Service mode: reload config, flatten layout, toggle float, close others
alt-shift-semicolon = 'mode service'

[mode.service.binding]
esc = ['reload-config', 'mode main']
r = ['flatten-workspace-tree', 'mode main']
f = ['layout floating tiling', 'mode main']
backspace = ['close-all-windows-but-current', 'mode main']
