{{- $primary := "Firefox" -}}
{{- $secondary := "Google Chrome" -}}
{{- if hasKey . "browser_primary"   }}{{ $primary   = .browser_primary   }}{{ end -}}
{{- if hasKey . "browser_secondary" }}{{ $secondary = .browser_secondary }}{{ end -}}
# AeroSpace — i3-like tiling WM. Alt acts as "Super" to mirror the Omarchy/hypr
# muscle memory; it is also AeroSpace's own default modifier and, unlike Cmd,
# carries no native macOS shortcuts to clash with. Only non-default options are
# set; omitted keys keep AeroSpace defaults. Tab is left unbound so AltTab keeps
# ⌥Tab. Validate edits with: aerospace reload-config --dry-run

start-at-login = true

# Native ⌘H hides an app, which yanks its window out of the tiler and leaves a
# hole in the layout; auto-unhiding pulls it back so tiling stays consistent
# (AeroSpace default for this is false).
automatically-unhide-macos-hidden-apps = true

# Launch JankyBorders (the `borders` daemon) at startup so the focused window
# gets a Nord frost-blue→white border — AeroSpace draws no decorations itself.
# The gradient is double-quoted so bash does not read its parens as a subshell.
after-startup-command = ['exec-and-forget borders active_color="gradient(top_left=0xff84b0c8,bottom_right=0xffeceff4)" inactive_color=0x00000000 width=5.0 style=round hidpi=on']

# Cursor lazily follows keyboard focus: focusing a window (alt-h/j/k/l, workspace
# switch) warps the pointer to it unless already inside it — mirrors Omarchy's
# default cursor warp on keybind focus (hypr cursor.no_warps=false). 'lazy' skips
# needless jumps. macOS has no focus-follows-mouse counterpart to hypr's
# follow_mouse=1, so this is the one direction that ports. Default is [].
on-focus-changed = ['move-mouse window-lazy-center']

[gaps]
inner.horizontal = 8
inner.vertical = 8
outer.left = 6
outer.right = 6
outer.top = 6
outer.bottom = 6

# Static workspace->monitor pins. Roles not ports, so it survives dock/undock:
# 'main' tracks the macOS Main display, 'built-in' the laptop panel — 1/2 land on
# main, 3/4 on the built-in. Workspace 5 pins to a third screen only when
# monitor_secondary is set in the local [data]; absent it, 5 falls back to the
# focused monitor. AeroSpace's 'secondary' keyword is avoided (valid only with
# exactly 2 monitors). 7-0 stay unpinned (focused); 6 is unbound (see bindings).
[workspace-to-monitor-force-assignment]
1 = 'main'
2 = 'main'
3 = 'built-in'
4 = 'built-in'
{{ if hasKey . "monitor_secondary" -}}
5 = '{{ .monitor_secondary }}'
{{ end -}}

# Workspaces occasionally initialize to the accordion (stacked) layout despite
# the 'tiles' default — upstream bug nikitabobko/AeroSpace#905. Rather than
# re-tile by hand with alt-/ each time, force 'tiles' on every detected window:
# a no-op when the container is already tiled, biting only when the stray
# accordion would appear. Trade-off: deliberate accordion is now unreachable,
# which costs nothing here since no key binds it.
[[on-window-detected]]
run = ['layout tiles']

[mode.main.binding]

# Window management. Fullscreen is on alt-semicolon, not alt-f — bare alt-f is
# left free so EurKEY's AltGr+f (right Alt) composes; semicolon's AltGr is unused.
alt-w = 'close'
alt-semicolon = 'fullscreen'
alt-slash = 'layout tiles horizontal vertical'
alt-minus = 'resize smart -50'
alt-equal = 'resize smart +50'

# Focus / move, vi-style — matches hypr bindings.conf (SUPER / SUPER+SHIFT H/J/K/L)
alt-h = 'focus left'
alt-j = 'focus down'
alt-k = 'focus up'
alt-l = 'focus right'
alt-shift-h = 'move left'
alt-shift-j = 'move down'
alt-shift-k = 'move up'
alt-shift-l = 'move right'

# Join-with (alt-ctrl + vi keys): pull the focused window and the neighbor in
# that direction into a shared tiling container — the i3-style way to build
# columns and quadrants. AeroSpace's default normalization flips each nested
# container's axis automatically, so joining in two directions yields a 2x2
# grid for free. alt-/ rotates the focused container's axis; service-mode 'r'
# (flatten-workspace-tree) collapses all structure back to a flat row.
alt-ctrl-h = 'join-with left'
alt-ctrl-j = 'join-with down'
alt-ctrl-k = 'join-with up'
alt-ctrl-l = 'join-with right'

# Workspaces (switch; shift = move window there and follow). 6 is deliberately
# left UNBOUND so EurKEY's circumflex dead key (Option+6, e.g. ê) composes:
# AeroSpace cannot tell left- from right-Option, so any alt-6 binding would eat
# it — the same concession already made for alt-f above. 1-5 pin per the
# assignment block; 7-0 are unpinned scratch workspaces on the focused monitor.
alt-1 = 'workspace 1'
alt-2 = 'workspace 2'
alt-3 = 'workspace 3'
alt-4 = 'workspace 4'
alt-5 = 'workspace 5'
alt-7 = 'workspace 7'
alt-8 = 'workspace 8'
alt-9 = 'workspace 9'
alt-0 = 'workspace 0'
alt-shift-1 = ['move-node-to-workspace 1', 'workspace 1']
alt-shift-2 = ['move-node-to-workspace 2', 'workspace 2']
alt-shift-3 = ['move-node-to-workspace 3', 'workspace 3']
alt-shift-4 = ['move-node-to-workspace 4', 'workspace 4']
alt-shift-5 = ['move-node-to-workspace 5', 'workspace 5']
alt-shift-7 = ['move-node-to-workspace 7', 'workspace 7']
alt-shift-8 = ['move-node-to-workspace 8', 'workspace 8']
alt-shift-9 = ['move-node-to-workspace 9', 'workspace 9']
alt-shift-0 = ['move-node-to-workspace 0', 'workspace 0']

# New terminal window in the *existing* Ghostty instance, via Ghostty 1.3+
# native AppleScript. Not `open -n -a Ghostty`: -n spawns a second app
# instance (extra dock icon), and macOS state restoration rebuilds the old
# split layout inside it. `new window` reuses the running app, fresh window.
alt-enter = '''exec-and-forget osascript -e 'tell application "Ghostty" to new window' '''

# Tmux in a fresh Ghostty window — mirrors hypr SUPER+ALT+RETURN. Omarchy's
# extra ALT becomes Cmd on macOS (Alt already plays SUPER), the convention for
# every alt-…-cmd binding here.
alt-cmd-enter = '''exec-and-forget osascript -e 'tell application "Ghostty" to new window with configuration {command:"tmux new"}' '''

# App launchers — open -a / -b is focus-or-launch. Mirrors hypr SUPER+SHIFT+<key>.
# Primary/secondary browser are per-machine: defaults are Firefox / Chrome;
# override browser_primary / browser_secondary in the local chezmoi [data].
alt-shift-b = 'exec-and-forget open -a "{{ $primary }}"'
alt-shift-cmd-b = 'exec-and-forget open -a "{{ $secondary }}"'
alt-shift-o = 'exec-and-forget open -a Obsidian'
alt-shift-t = 'exec-and-forget open -a "Activity Monitor"'
# Dual-mode apps: launch-app-or-webapp prefers the native app and falls back to
# a chromeless web-app window when it is absent (open -a exits nonzero, having
# launched nothing). Mirrors the hypr bindings of the same name.
alt-shift-g = 'exec-and-forget $HOME/.config/aerospace/launch-app-or-webapp Telegram Telegram https://web.telegram.org/a/'
alt-shift-m = 'exec-and-forget $HOME/.config/aerospace/launch-app-or-webapp Spotify Spotify https://open.spotify.com'
alt-shift-s = 'exec-and-forget $HOME/.config/aerospace/launch-app-or-webapp Slack Slack https://app.slack.com/client'
# Steam and Passwords have no web equivalent, so plain open -a — a no-op until
# the app is installed, letting the binding ship ahead of install. Passwords is
# on alt-shift-slash since bare alt-slash already cycles the tiling layout.
alt-shift-cmd-s = 'exec-and-forget open -a Steam'
alt-shift-slash = 'exec-and-forget open -a Bitwarden'
# Claude desktop app by bundle id, not name — `open -a Claude` would fuzzy-match
# the "Claude Code URL Handler" helper; the bundle id targets Claude.app exactly.
alt-shift-cmd-a = 'exec-and-forget open -b com.anthropic.claudefordesktop'
# Finder opens a fresh window each press (make new Finder window) rather than
# focusing the existing one, then activates to pull focus to it.
alt-shift-f = '''exec-and-forget osascript -e 'tell application "Finder" to make new Finder window' -e 'tell application "Finder" to activate' '''

# Like alt-enter but opens the fresh Ghostty window straight into nvim. Same
# reason for AppleScript over `open -n`: reuse the instance, skip restoration.
alt-shift-n = '''exec-and-forget osascript -e 'tell application "Ghostty" to new window with configuration {command:"nvim"}' '''

# Same Ghostty-with-command pattern for Omarchy's TUI launchers — Docker
# (lazydocker, SUPER+SHIFT+D) and the music TUI (cliamp, SUPER+SHIFT+ALT+M).
alt-shift-d = '''exec-and-forget osascript -e 'tell application "Ghostty" to new window with configuration {command:"lazydocker"}' '''
alt-shift-cmd-m = '''exec-and-forget osascript -e 'tell application "Ghostty" to new window with configuration {command:"cliamp"}' '''

# Web apps as chromeless Chrome --app windows. Gmail and Calendar launch-or-
# focus: focus an existing window by a page-<title> substring (launch-or-focus-
# webapp, our AeroSpace port of omarchy-launch-or-focus-webapp), else launch.
# Patterns stay stable across views/branding — Gmail matches "Mail" (a Workspace
# tab is titled "<org> Mail", never "Gmail"); Calendar matches "Calendar". ChatGPT
# and YouTube intentionally open a fresh window each press, via the Chrome binary
# directly because `open --args` is ignored when Chrome is already running.
alt-shift-a = '''exec-and-forget "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" --app=https://chatgpt.com'''
alt-shift-e = 'exec-and-forget $HOME/.config/aerospace/launch-or-focus-webapp Mail https://mail.google.com/mail/'
alt-shift-c = 'exec-and-forget $HOME/.config/aerospace/launch-or-focus-webapp Calendar https://calendar.google.com/calendar/u/0/r'
alt-shift-y = '''exec-and-forget "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" --app=https://youtube.com'''
# WhatsApp prefers WhatsApp.app if installed, else launch-or-focuses the web
# window by page title (via launch-app-or-webapp; mirrors hypr SUPER+SHIFT+ALT+G).
# Infomaniak mail opens a fresh --app window, matching Omarchy's plain launch.
alt-shift-cmd-g = 'exec-and-forget $HOME/.config/aerospace/launch-app-or-webapp WhatsApp WhatsApp https://web.whatsapp.com/'
alt-shift-cmd-e = '''exec-and-forget "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" --app=https://ksuite.infomaniak.com/all/mail/'''

# Android hotspot: bounce Bluetooth so the phone's Tasker profile
# starts its hotspot, then join it. Runs the script directly (no Raycast).
# Per-machine setup + phone side: guides/android-hotspot-bluetooth-setup.md.
alt-ctrl-cmd-b = 'exec-and-forget $HOME/.local/bin/android-hotspot start'

# Service mode: reload config, flatten layout, toggle float, close others
alt-shift-semicolon = 'mode service'

[mode.service.binding]
esc = ['reload-config', 'mode main']
r = ['flatten-workspace-tree', 'mode main']
f = ['layout floating tiling', 'mode main']
backspace = ['close-all-windows-but-current', 'mode main']
