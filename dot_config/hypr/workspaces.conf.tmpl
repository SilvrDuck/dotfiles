# Static workspace->monitor pins (row-major pairs), unified with the macOS
# AeroSpace scheme. Roles come from the local chezmoi [data]; each pair is
# emitted only if its key is set, so a missing display drops its rules instead
# of pinning an empty desc. ws 1/3/5 are each monitor's default. 7-0 unpinned.
{{ if hasKey . "monitor_main" -}}
workspace = 1, monitor:desc:{{ .monitor_main }}, default:true
workspace = 2, monitor:desc:{{ .monitor_main }}
{{ end -}}
{{ if hasKey . "monitor_secondary" -}}
workspace = 3, monitor:desc:{{ .monitor_secondary }}, default:true
workspace = 4, monitor:desc:{{ .monitor_secondary }}
{{ end -}}
{{ if hasKey . "monitor_builtin" -}}
workspace = 5, monitor:desc:{{ .monitor_builtin }}, default:true
workspace = 6, monitor:desc:{{ .monitor_builtin }}
{{ end -}}
