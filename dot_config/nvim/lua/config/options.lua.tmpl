-- Options are automatically loaded before lazy.nvim startup
-- Default options that are always set: https://github.com/LazyVim/LazyVim/blob/main/lua/lazyvim/config/options.lua
-- Add any additional options here

vim.g.dotfiles_machine_kind = "{{ .machine_kind }}"

vim.g.loaded_perl_provider = 0
vim.g.loaded_ruby_provider = 0

vim.opt.number = true -- show current line number
vim.opt.relativenumber = true -- show relative numbers around cursor

vim.opt.scrolloff = 999 -- typewriter scroll: keep cursor vertically centered

-- LazyVim defaults clipboard to "unnamedplus", which routes d/x/c to the system
-- clipboard too. Unset it so only yanks reach `+` (via TextYankPost in autocmds.lua);
-- deletes stay in the unnamed register for in-nvim paste without clobbering OS clipboard.
vim.opt.clipboard = ""

-- ty is Astral's Rust-based type checker (10-100x faster than pyright). Beta:
-- expect occasional breakage on upgrades. LazyVim's python extra defaults to
-- pyright; the extra wires up whatever name is here via nvim-lspconfig + mason.
vim.g.lazyvim_python_lsp = "ty"

