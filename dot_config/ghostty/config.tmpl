{{ if .is_mac -}}
{{- if stat "/opt/homebrew/bin/zsh" -}}
command = /opt/homebrew/bin/zsh --login
{{- else if stat "/usr/local/bin/zsh" -}}
command = /usr/local/bin/zsh --login
{{- else -}}
command = /bin/zsh --login
{{- end }}
{{ else -}}
command = /usr/bin/env zsh --login
{{- end }}

font-family = "JetBrainsMonoNL Nerd Font"
font-size = {{ if .is_mac }}14{{ else }}9{{ end }}

theme = Nord

background-opacity = 0.9
window-padding-x = 12
window-padding-y = 8

cursor-style = block
cursor-style-blink = false

shell-integration = zsh
shell-integration-features = sudo,cursor

clipboard-read = allow
clipboard-write = allow
copy-on-select = clipboard

{{ if .is_mac -}}
macos-titlebar-style = tabs
# right Option = AltGr so EurKEY composes accents in nvim; left Option stays Meta for zsh word-jump
macos-option-as-alt = left
{{- end }}

confirm-close-surface = false
