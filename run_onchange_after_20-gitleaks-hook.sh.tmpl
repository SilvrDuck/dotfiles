#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git -C "{{ .chezmoi.sourceDir }}" rev-parse --show-toplevel 2>/dev/null || true)"
[ -n "$REPO_ROOT" ] || exit 0

HOOK_DIR="$REPO_ROOT/.git/hooks"
HOOK_FILE="$HOOK_DIR/pre-commit"
CONFIG_FILE="$REPO_ROOT/.gitleaks.toml"
LOCAL_CONFIG_FILE="$REPO_ROOT/.gitleaks.local.toml"
LINTER="$REPO_ROOT/tools/lint-comments"

[ -d "$HOOK_DIR" ] || exit 0

# Pre-commit hook: gitleaks for secrets, then the trailing-comment-style
# lint on staged files. Both must pass for the commit to proceed.
cat > "$HOOK_FILE" <<EOF2
#!/bin/sh
if ! command -v gitleaks >/dev/null 2>&1; then
  echo "gitleaks is required for commits in this repo."
  exit 1
fi
# Prefer the gitignored local config (extends the tracked one with
# machine-only sensitive substrings); fall back to the tracked config.
if [ -f "$LOCAL_CONFIG_FILE" ]; then
  CFG="$LOCAL_CONFIG_FILE"
else
  CFG="$CONFIG_FILE"
fi
gitleaks git --config "\$CFG" --pre-commit --staged --redact --verbose || exit 1

if [ -x "$LINTER" ]; then
  git diff --cached --name-only --diff-filter=ACMR | while IFS= read -r f; do
    [ -f "\$f" ] || continue
    "$LINTER" "\$f" || exit 1
  done
fi
EOF2

chmod +x "$HOOK_FILE"
