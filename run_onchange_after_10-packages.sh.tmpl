#!/usr/bin/env bash
set -euo pipefail

# machine_kind: {{ .machine_kind }}
# package data hash: {{ include ".chezmoidata/packages.yaml" | sha256sum }}

if command -v sudo >/dev/null 2>&1; then
  SUDO=sudo
else
  SUDO=
fi

{{ $allTools := list }}
{{ range $groupName, $tools := .packages.groups }}
{{ if or (ne $groupName "desktop") (ne $.machine_kind "devcontainer") }}
{{ range $tool := $tools }}
{{ $allTools = append $allTools $tool }}
{{ end }}
{{ end }}
{{ end }}

{{ template "package-manager-helpers.sh" . }}

{{ if eq .chezmoi.os "darwin" }}
if [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# -----------------------------------------------------------------------------
# Install packages
# -----------------------------------------------------------------------------

{{ range $tool := $allTools }}
{{ $name := $tool }}
{{ $kind := "brew" }}
{{ $skip := false }}
{{ with (index $.packages.overrides $tool) }}
{{ with (index . "darwin") }}{{ $name = . }}{{ end }}
{{ with (index . "darwin_kind") }}{{ $kind = . }}{{ end }}
{{ with (index . "darwin_skip") }}{{ $skip = . }}{{ end }}
{{ end }}
{{ if not $skip }}
install_brew {{ $kind | quote }} {{ $name | quote }}
{{ end }}
{{ end }}

{{ else if eq .chezmoi.os "linux" }}
if command -v pacman >/dev/null 2>&1; then

{{ range $tool := $allTools }}
{{ $name := $tool }}
{{ $aur := "" }}
{{ $skip := false }}
{{ with (index $.packages.overrides $tool) }}
{{ with (index . "pacman") }}{{ $name = . }}{{ end }}
{{ with (index . "pacman_aur") }}{{ $aur = . }}{{ end }}
{{ with (index . "linux_skip") }}{{ $skip = . }}{{ end }}
{{ end }}
{{ if not $skip }}
{{ if $aur }}
  install_yay {{ $aur | quote }}
{{ else }}
  install_pacman {{ $name | quote }}
{{ end }}
{{ end }}
{{ end }}

elif command -v apt-get >/dev/null 2>&1; then
  $SUDO apt-get update || true

{{ template "apt-manual-installers.sh" . }}

{{ range $tool := $allTools }}
{{ $name := $tool }}
{{ $manual := "" }}
{{ $skip := false }}
{{ with (index $.packages.overrides $tool) }}
{{ with (index . "apt") }}{{ $name = . }}{{ end }}
{{ with (index . "apt_manual") }}{{ $manual = . }}{{ end }}
{{ with (index . "linux_skip") }}{{ $skip = . }}{{ end }}
{{ end }}
{{ if not $skip }}
{{ if eq $manual "antidote_git" }}
  install_manual_antidote
{{ else if eq $manual "neovim_tarball" }}
  install_manual_neovim
{{ else if eq $manual "starship_script" }}
  install_manual_starship
{{ else if eq $manual "mise_script" }}
  install_manual_mise
{{ else if eq $manual "eza_release" }}
  install_manual_eza
{{ else if eq $manual "carapace_release" }}
  install_manual_carapace
{{ else if eq $manual "lazygit_release" }}
  install_manual_lazygit
{{ else if eq $manual "pay_respects_release" }}
  install_manual_pay_respects
{{ else if eq $manual "d2_script" }}
  install_manual_d2
{{ else if eq $manual "xh_release" }}
  install_manual_xh
{{ else if eq $manual "jetbrains_mono_nerd" }}
  install_manual_jetbrains_mono_nerd
{{ else }}
  install_apt {{ $name | quote }}
{{ end }}
{{ end }}
{{ end }}

else
  echo "[packages] Supported Linux package managers: pacman or apt-get. Continuing without package install." >&2
fi
{{ end }}

# -----------------------------------------------------------------------------
# Upstream installers (AI CLIs, uv, and a few tools with broken packages)
# -----------------------------------------------------------------------------

{{ template "upstream-installers.sh" . }}

# -----------------------------------------------------------------------------
# Default login shell -> zsh (Linux only; macOS uses its own flow)
# -----------------------------------------------------------------------------

{{ if eq .chezmoi.os "linux" }}
zsh_path="$(command -v zsh || true)"
if [ -n "$zsh_path" ]; then
  current="$(getent passwd "$USER" 2>/dev/null | cut -d: -f7 || true)"
  if [ "$current" != "$zsh_path" ]; then
    # chsh refuses shells not listed in /etc/shells on most distros.
    if [ -f /etc/shells ] && ! grep -qxF "$zsh_path" /etc/shells 2>/dev/null; then
      echo "$zsh_path" | $SUDO tee -a /etc/shells >/dev/null 2>&1 || true
    fi
    if $SUDO chsh -s "$zsh_path" "$USER" >/dev/null 2>&1; then
      echo "[shell] login shell set to $zsh_path (open a new terminal to pick it up)"
    else
      echo "[shell] skipped: run 'chsh -s $zsh_path' manually"
    fi
  fi
fi
{{ end }}
