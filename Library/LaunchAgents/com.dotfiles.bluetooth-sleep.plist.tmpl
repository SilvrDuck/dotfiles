<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.dotfiles.bluetooth-sleep</string>
	<key>ProgramArguments</key>
	<array>
		<string>{{ if eq .chezmoi.arch "arm64" }}/opt/homebrew{{ else }}/usr/local{{ end }}/sbin/sleepwatcher</string>
		<string>-V</string>
		<string>-s</string>
		<string>{{ .chezmoi.homeDir }}/.local/bin/bt-sleep sleep</string>
		<string>-w</string>
		<string>{{ .chezmoi.homeDir }}/.local/bin/bt-sleep wake</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>ProcessType</key>
	<string>Background</string>
	<key>StandardOutPath</key>
	<string>{{ .chezmoi.homeDir }}/.local/state/bluetooth-sleep/agent.log</string>
	<key>StandardErrorPath</key>
	<string>{{ .chezmoi.homeDir }}/.local/state/bluetooth-sleep/agent.log</string>
</dict>
</plist>
