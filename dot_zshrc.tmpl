# -----------------------------------------------------------------------------
# Editor
# -----------------------------------------------------------------------------

export EDITOR=nvim  # default CLI editor
export VISUAL=nvim  # visual editor

{{ if .is_mac -}}
# -----------------------------------------------------------------------------
# Homebrew
# -----------------------------------------------------------------------------

if [ -x /opt/homebrew/bin/brew ]; then  # Apple Silicon path
  eval "$(/opt/homebrew/bin/brew shellenv)"  # expose brew
elif [ -x /usr/local/bin/brew ]; then  # Intel path
  eval "$(/usr/local/bin/brew shellenv)"  # expose brew
fi
{{- end }}

# -----------------------------------------------------------------------------
# PATH
# -----------------------------------------------------------------------------

export PATH="$HOME/.local/bin:$HOME/.opencode/bin:$PATH"  # user bins first

# -----------------------------------------------------------------------------
# History
# -----------------------------------------------------------------------------

HISTSIZE=100000  # memory history
SAVEHIST=100000  # saved history
HISTFILE="$HOME/.zsh_history"  # history file

setopt SHARE_HISTORY  # sync shells
setopt HIST_IGNORE_DUPS  # skip dupes
setopt HIST_IGNORE_SPACE  # hide leading-space cmds
setopt INTERACTIVE_COMMENTS  # allow comments

# -----------------------------------------------------------------------------
# Completion styles
# -----------------------------------------------------------------------------

zstyle ':completion:*' menu no  # let fzf-tab own menu
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'  # case-insensitive
zstyle ':completion:*:-command-:*' tag-order 'commands functions builtins reserved-words aliases'  # no env vars in command position
zstyle ':fzf-tab:*' fzf-flags --height=40% --reverse --border  # compact UI

# -----------------------------------------------------------------------------
# Antidote phase 1
# Load fpath plugins before compinit.
# -----------------------------------------------------------------------------

{{ if .is_mac -}}
ANTIDOTE_ZSH="$(brew --prefix 2>/dev/null)/opt/antidote/share/antidote/antidote.zsh"  # brew antidote

if [ -r "$ANTIDOTE_ZSH" ]; then  # antidote installed
  source "$ANTIDOTE_ZSH"  # load antidote
fi
{{ else -}}
if [ -r /usr/share/zsh-antidote/antidote.zsh ]; then  # distro antidote
  source /usr/share/zsh-antidote/antidote.zsh  # load antidote
elif [ -r "$HOME/.local/share/antidote/antidote.zsh" ]; then  # manual antidote
  source "$HOME/.local/share/antidote/antidote.zsh"  # load antidote
fi
{{- end }}

if command -v antidote >/dev/null; then  # antidote loaded
  antidote load ${ZDOTDIR:-$HOME}/.zsh_plugins_fpath.txt  # fpath before compinit
fi

# -----------------------------------------------------------------------------
# Completion engine
# -----------------------------------------------------------------------------

autoload -Uz compinit  # load completion init
if [[ -n ${ZDOTDIR:-$HOME}/.zcompdump(#qNmh+24) ]]; then
  compinit  # full audit + dump regen once a day
else
  compinit -C  # skip audit when dump is fresh
fi

# -----------------------------------------------------------------------------
# Carapace
# -----------------------------------------------------------------------------

if command -v carapace >/dev/null; then  # rich completions available
  export CARAPACE_BRIDGES='zsh,fish,bash'  # completion bridges
  cache="${ZDOTDIR:-$HOME}/.cache/carapace.zsh"  # init cache
  if [[ ! -s $cache || $(command -v carapace) -nt $cache ]]; then
    mkdir -p ${cache:h}  # ensure cache dir
    carapace _carapace > $cache  # regen on binary change
  fi
  source $cache  # load cached init
  unset cache
fi

# -----------------------------------------------------------------------------
# Antidote phase 2
# Load widget plugins after compinit.
# -----------------------------------------------------------------------------

if command -v antidote >/dev/null; then  # antidote loaded
  antidote load ${ZDOTDIR:-$HOME}/.zsh_plugins_after_compinit.txt  # widgets after compinit
fi

# -----------------------------------------------------------------------------
# Vi mode
# -----------------------------------------------------------------------------

bindkey -v  # native vi mode
KEYTIMEOUT=20  # faster key sequences

bindkey -M viins 'jk' vi-cmd-mode  # jk escapes insert
bindkey -M viins 'kj' vi-cmd-mode  # kj escapes insert
bindkey -M viins 'ç' fzf-cd-widget  # Alt+C eurkey override
bindkey -M vicmd 'ç' fzf-cd-widget  # Alt+C eurkey override
bindkey -M viins '^?' backward-delete-char  # backspace crosses lines
bindkey -M viins '^H' backward-delete-char  # ditto (some terminals)
bindkey -M viins '^W' backward-kill-word    # ctrl-w crosses lines

function zle-keymap-select zle-line-init {
  case $KEYMAP in
    vicmd) printf '\e[2 q' ;;  # block cursor
    viins|main) printf '\e[6 q' ;;  # beam cursor
  esac
}

zle -N zle-keymap-select  # cursor on mode switch
zle -N zle-line-init  # cursor on prompt start

function zle-line-finish {
  printf '\e[6 q'  # reset cursor
}

zle -N zle-line-finish  # cursor on prompt end

function vi-dd-clear-line-insert {
  BUFFER=""  # clear line
  CURSOR=0  # start of line
  zle vi-insert  # back to insert
}

zle -N vi-dd-clear-line-insert  # register widget
bindkey -M vicmd 'dd' vi-dd-clear-line-insert  # dd clears and inserts

# -----------------------------------------------------------------------------
# History search
# -----------------------------------------------------------------------------

autoload -Uz up-line-or-beginning-search down-line-or-beginning-search  # prefix search

zle -N up-line-or-beginning-search  # register up search
zle -N down-line-or-beginning-search  # register down search

bindkey '^[[A' up-line-or-beginning-search  # up searches prefix
bindkey '^[[B' down-line-or-beginning-search  # down searches prefix

{{ if eq .machine_kind "omarchy" -}}
# -----------------------------------------------------------------------------
# Omarchy prompt
# -----------------------------------------------------------------------------

if [ -f "$HOME/.config/omarchy/current/theme/starship.toml" ]; then  # Omarchy theme exists
  export STARSHIP_CONFIG="$HOME/.config/omarchy/current/theme/starship.toml"  # use Omarchy theme
fi
{{- end }}

# -----------------------------------------------------------------------------
# Prompt
# -----------------------------------------------------------------------------

command -v starship >/dev/null && eval "$(starship init zsh)"  # load prompt

# -----------------------------------------------------------------------------
# fzf
# -----------------------------------------------------------------------------

if command -v fzf >/dev/null; then  # fzf installed
{{ if .is_mac -}}
  source <(fzf --zsh)  # fzf keybinds
{{ else -}}
  source /usr/share/fzf/key-bindings.zsh 2>/dev/null  # fzf keys
  source /usr/share/fzf/completion.zsh 2>/dev/null  # fzf completion
{{- end }}
fi

export FZF_CTRL_R_OPTS="
  --reverse
  --height=40%
  --bind 'ctrl-/:toggle-preview'
  --preview-window=down,3,wrap
"  # history picker layout

bindkey 'ç' fzf-cd-widget  # Alt+C eurkey override

# -----------------------------------------------------------------------------
# Directory jumping
# -----------------------------------------------------------------------------

export _ZO_DOCTOR=0  # doctor's "init last" rule is a false positive here
command -v zoxide >/dev/null && eval "$(zoxide init zsh --cmd cd)"  # smart cd

# -----------------------------------------------------------------------------
# Runtime management
# -----------------------------------------------------------------------------

export MISE_IGNORED_CONFIG_PATHS="{{ .chezmoi.sourceDir }}"  # skip chezmoi source mise.toml
command -v mise >/dev/null && eval "$(mise activate zsh)"  # runtime shims

# -----------------------------------------------------------------------------
# Command correction
# -----------------------------------------------------------------------------

export _PR_AI_DISABLE=1  # opt out of pay-respects AI suggestions
if command -v pay-respects >/dev/null; then  # pay-respects installed
  eval "$(pay-respects zsh --alias f)"  # rerun corrected command via `f`
  alias F=f fuck=f  # extra triggers
fi

# -----------------------------------------------------------------------------
# Modern CLI aliases
# -----------------------------------------------------------------------------

alias ls='eza --icons --group-directories-first'  # better ls
alias ll='eza -lah --icons --group-directories-first --git'  # long ls
alias la='eza -a --icons --group-directories-first'  # all files
alias tree='eza --tree --icons --git-ignore'  # tree view

if command -v bat >/dev/null 2>&1; then  # bat installed
  alias cat='bat --style=plain --paging=never'  # better cat
elif command -v batcat >/dev/null 2>&1; then  # Debian name
  alias cat='batcat --style=plain --paging=never'  # better cat
fi

if ! command -v fd >/dev/null 2>&1 && command -v fdfind >/dev/null 2>&1; then  # Debian name
  alias fd='fdfind'  # normalize fd
fi

alias top='btop'  # better top
alias du='dust'  # better du
alias ps='procs'  # better ps
alias lg='lazygit'  # git UI

# Cross-platform clipboard: macOS pbcopy, Wayland wl-copy, X11 xclip fallback
if command -v pbcopy >/dev/null 2>&1; then
  alias clip='pbcopy'
elif [ -n "${WAYLAND_DISPLAY:-}" ] && command -v wl-copy >/dev/null 2>&1; then
  alias clip='wl-copy'
elif command -v xclip >/dev/null 2>&1; then
  alias clip='xclip -selection clipboard'
fi
ob() { cd ~/vaults/main && nvim "${@:-.}"; }  # open vault in nvim
myconf() {  # edit dotfiles with Claude; nag if a chezmoi update is pending
  local src behind drift ans
  src="$(chezmoi source-path)" || return
  cd "$src" || return
  git fetch --quiet 2>/dev/null  # refresh refs so 'behind' is accurate; offline-tolerant
  behind=$(git rev-list --count HEAD..@{upstream} 2>/dev/null || echo 0)
  drift=$(chezmoi status 2>/dev/null | grep -c .)
  if [ "$behind" -gt 0 ] || [ "$drift" -gt 0 ]; then
    print -P "%F{yellow}chezmoi update pending:%f"
    [ "$behind" -gt 0 ] && print "  • $behind commit(s) behind origin/$(git rev-parse --abbrev-ref HEAD)"
    [ "$drift" -gt 0 ] && print "  • $drift path(s) differ from source (chezmoi apply)"
    read -r "ans?run 'chezmoi update' now? [Y/n] "
    case "${ans:l}" in
      n|no) ;;
      *) chezmoi update ;;
    esac
  fi
  claude "$@"
}

command -v claude >/dev/null && alias cc='claude'  # short Claude

# -----------------------------------------------------------------------------
# Local overrides
# -----------------------------------------------------------------------------

[ -f "$HOME/.zshrc.local" ] && source "$HOME/.zshrc.local"  # machine-local config

# -----------------------------------------------------------------------------
# Local secrets
# -----------------------------------------------------------------------------

if [ -d "$HOME/.config/dotfiles/secrets/env.d" ]; then  # local secrets dir
  for f in "$HOME"/.config/dotfiles/secrets/env.d/*.zsh(N); do  # each secret file
    source "$f"  # load secrets
  done
fi
