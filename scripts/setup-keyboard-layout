#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  cat <<'HELP'
setup-keyboard-layout

One-time EurKEY keyboard setup.

macOS:
  Installs the latest EurKEY Next release that ships a .dmg asset into:
    ~/Library/Keyboard Layouts
  (Upstream re-tags occasionally without assets; this picks the newest with one.)

  Also installs a hidutil LaunchAgent that swaps the grave (`) and §/± keys,
  fixing the Apple ISO position where the top-left key types § instead of `.

Linux:
  Checks whether the EurKEY XKB layout is available.
  Prints the commands to apply it for X11/desktop environments.

After macOS install, log out and back in, then in:
  System Settings -> Keyboard -> Input Sources
add "EurKEY Next" and remove any older EurKey entry (e.g. "EurKEY v2.0") —
a stale entry masks the grave/§ swap if it gets reselected.
HELP
  exit 0
fi

case "$(uname -s)" in
  Darwin)
    if ! command -v jq >/dev/null 2>&1; then
      echo "jq is required. Run chezmoi apply first so packages are installed."
      exit 1
    fi

    tmpdir="$(mktemp -d)"
    trap 'rm -rf "$tmpdir"' EXIT

    echo "[eurkey] Finding latest EurKEY Next release with a .dmg asset"
    read -r tag dmg_url < <(
      curl -fsSL https://api.github.com/repos/felixfoertsch/EurKEY-Next/releases \
        | jq -r '
            map(select(.draft == false and .prerelease == false))
            | map({tag: .tag_name, dmg: (.assets[] | select(.name | test("\\.dmg$")) | .browser_download_url)})
            | first
            | "\(.tag) \(.dmg)"
          '
    )

    if [[ -z "${dmg_url:-}" || "$dmg_url" == "null" ]]; then
      echo "No EurKEY Next release with a .dmg asset found."
      echo "Open manually: https://github.com/felixfoertsch/EurKEY-Next/releases"
      exit 1
    fi

    echo "[eurkey] Using release $tag"

    echo "[eurkey] Downloading $dmg_url"
    curl -fL "$dmg_url" -o "$tmpdir/EurKEY-Next.dmg"

    echo "[eurkey] Mounting DMG"
    mount_dir="$tmpdir/mnt"
    mkdir -p "$mount_dir"
    hdiutil attach "$tmpdir/EurKEY-Next.dmg" -mountpoint "$mount_dir" -nobrowse -quiet

    layout_dir="$HOME/Library/Keyboard Layouts"
    mkdir -p "$layout_dir"

    bundle_path="$(find "$mount_dir" -name 'EurKEY-Next.bundle' -maxdepth 3 -print -quit)"

    if [[ -z "$bundle_path" ]]; then
      hdiutil detach "$mount_dir" -quiet || true
      echo "Could not find EurKEY-Next.bundle inside the DMG."
      exit 1
    fi

    # Remove any previously installed EurKey layouts (including the orphaned
    # EurKey-macOS.bundle that ships "EurKEY v2.0") so only the freshly built
    # EurKEY Next remains. A stale bundle otherwise lingers as a selectable
    # input source, and the grave/§ swap does not surface on it — reselecting
    # it by accident makes the fix look broken. -iname matches case-insensitively.
    echo "[eurkey] Removing previously installed EurKey layouts"
    find "$layout_dir" -maxdepth 1 -iname 'EurKey*.bundle' -exec rm -rf {} +

    echo "[eurkey] Installing bundle to $layout_dir"
    cp -R "$bundle_path" "$layout_dir/"

    hdiutil detach "$mount_dir" -quiet || true

    echo "[eurkey] Installing grave / § key swap (hidutil LaunchAgent)"

    # Apple ISO keyboards emit the Grave/Tilde (0x35) and Non-US \ / § (0x64) HID
    # usages in swapped positions: the top-left key types §, while the key next to
    # left Shift types `. hidutil remaps the two usages below the keyboard layout,
    # so EurKEY receives them the right way round regardless of the active layout.
    # The mapping does not survive a reboot, hence a RunAtLoad LaunchAgent.
    swap_label="local.eurkey.grave-section-swap"
    swap_plist="$HOME/Library/LaunchAgents/$swap_label.plist"
    swap_mapping='{"UserKeyMapping":[{"HIDKeyboardModifierMappingSrc":0x700000035,"HIDKeyboardModifierMappingDst":0x700000064},{"HIDKeyboardModifierMappingSrc":0x700000064,"HIDKeyboardModifierMappingDst":0x700000035}]}'
    mkdir -p "$HOME/Library/LaunchAgents"

    cat > "$swap_plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$swap_label</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/hidutil</string>
    <string>property</string>
    <string>--set</string>
    <string>$swap_mapping</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
PLIST

    # bootstrap runs the agent immediately (RunAtLoad) and re-runs it at every
    # login; bootout first so a re-run replaces any stale copy.
    launchctl bootout "gui/$(id -u)/$swap_label" 2>/dev/null || true
    if launchctl bootstrap "gui/$(id -u)" "$swap_plist" 2>/dev/null; then
      echo "[eurkey] grave / § swap active now and at every login."
    else
      echo "[eurkey] Swap plist installed; applying once for this session."
      /usr/bin/hidutil property --set "$swap_mapping" >/dev/null || true
    fi

    cat <<DONE

EurKEY Next $tag installed; grave / § keys swapped.

Now:
  1. Log out and back in, or restart.
  2. Open System Settings -> Keyboard -> Input Sources.
  3. Add "EurKEY Next".

DONE
    ;;

  Linux)
    echo "[eurkey] Checking XKB layouts"

    if command -v localectl >/dev/null 2>&1; then
      echo
      echo "Available EurKEY-like layouts:"
      localectl list-x11-keymap-layouts | grep -Ei '^(eu|eurkey)$' || true
    fi

    if [ -d /usr/share/X11/xkb ]; then
      echo
      echo "XKB data exists at /usr/share/X11/xkb."
    else
      echo
      echo "XKB data not found. Install your distro XKB package:"
      echo "  Arch/pacman: xkeyboard-config"
      echo "  Debian/Ubuntu/apt: xkb-data"
    fi

    cat <<'LINUX'

For an X11 session, try:

  setxkbmap eu

If your distro uses the legacy EurKEY package/layout name, try:

  setxkbmap eurkey

For persistent setup, use your desktop environment keyboard settings.

On GNOME/Ubuntu, EurKEY may be hidden until extended input sources are enabled:

  gsettings set org.gnome.desktop.input-sources show-all-sources true

On Hyprland/Omarchy, set it in the compositor input config rather than relying on setxkbmap.

LINUX
    ;;

  *)
    echo "Unsupported OS."
    exit 1
    ;;
esac