#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  cat <<'HELP'
setup-git-default-context

One-time default Git setup for this machine.

Performs:
  1. Asks for your default Git display name and email.
  2. Creates ~/.ssh/id_ed25519 if missing.
  3. Writes ~/.config/git/config.
  4. Includes ~/.config/git/git-defaults.
  5. Sets default [user] name/email.
  6. Prints ~/.ssh/id_ed25519.pub for manual provider registration.
HELP
  exit 0
fi

ask() {
  local prompt="$1" default="${2:-}" ans
  if [[ -n "$default" ]]; then
    read -r -p "$prompt [$default]: " ans
    echo "${ans:-$default}"
  else
    read -r -p "$prompt: " ans
    echo "$ans"
  fi
}

mkdir -p "$HOME/.ssh" "$HOME/.config/git"
chmod 700 "$HOME/.ssh"

default_name="$(git config --global user.name 2>/dev/null || true)"
default_email="$(git config --global user.email 2>/dev/null || true)"

name="$(ask 'Default Git display name' "$default_name")"
email="$(ask 'Default Git email' "$default_email")"

key="$HOME/.ssh/id_ed25519"

if [[ ! -f "$key" ]]; then
  ssh-keygen -t ed25519 -f "$key" -C "$(whoami)@$(hostname -s)-default"
fi

main="$HOME/.config/git/config"
touch "$main"
chmod 600 "$main"

if ! grep -qF 'path = ~/.config/git/git-defaults' "$main"; then
  cat >> "$main" <<'EOF2'
[include]
    path = ~/.config/git/git-defaults

EOF2
fi

# Replace or add default user block.
tmp="$(mktemp)"
awk '
  BEGIN { skip = 0 }
  /^\[user\]/ { skip = 1; next }
  /^\[/ { skip = 0 }
  skip == 0 { print }
' "$main" > "$tmp"

cat >> "$tmp" <<EOF2
[user]
    name = $name
    email = $email
EOF2

mv "$tmp" "$main"
chmod 600 "$main"

# Switch the chezmoi repo's own origin from HTTPS to SSH so `git push` here
# uses the key we just generated instead of prompting for HTTPS credentials.
# `chezmoi init` clones via HTTPS by default; this realigns it post-setup.
src="$(chezmoi source-path 2>/dev/null || true)"
if [[ -n "$src" ]] && pushd "$src" >/dev/null 2>&1; then
  url="$(git remote get-url origin 2>/dev/null || true)"
  case "$url" in
    https://github.com/*)
      new="git@github.com:${url#https://github.com/}"
      git remote set-url origin "$new"
      echo "Switched chezmoi origin to SSH: $new"
      ;;
  esac
  popd >/dev/null
fi

# Same idea for the SilvrDuck skills external: chezmoi clones it over anonymous
# HTTPS (so a key-less first apply still works) and keeps pulling it that way,
# so switch only its *push* URL to SSH — fetch stays HTTPS. Skip if not cloned.
skills="$HOME/.local/share/silvrduck-skills"
if [[ -d "$skills/.git" ]]; then
  fetch="$(git -C "$skills" remote get-url origin 2>/dev/null || true)"
  push="$(git -C "$skills" remote get-url --push origin 2>/dev/null || true)"
  case "$fetch" in
    https://github.com/*)
      want="git@github.com:${fetch#https://github.com/}"
      if [[ "$push" != "$want" ]]; then
        git -C "$skills" remote set-url --push origin "$want"
        echo "Switched skills external push to SSH: $want"
      fi
      ;;
  esac
fi

cat <<EOF2

Default Git context created.

Config:
  ~/.config/git/config

Default SSH key:
  $key

Add this public key to GitHub/GitLab manually:

$(cat "$key.pub")

Suggested checks:
  git config --show-origin user.name
  git config --show-origin user.email
  ssh -T git@github.com
  ssh -T git@gitlab.com

EOF2