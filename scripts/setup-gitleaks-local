#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  cat <<'HELP'
setup-gitleaks-local

Interactive setup for the machine-local gitleaks config that extends the
tracked .gitleaks.toml with extra soft-disclosure terms (employer names,
work email domains, internal hostnames, etc.).

The resulting file is gitignored — its substrings never reach the public
remote, but the pre-commit hook still scans every staged change against them.

Writes:  <repo>/.gitleaks.local.toml
Used by: <repo>/.git/hooks/pre-commit  (installed by chezmoi)
HELP
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "$REPO_ROOT" ]]; then
  echo "Run this from inside the chezmoi source repo." >&2
  exit 1
fi

OUT="$REPO_ROOT/.gitleaks.local.toml"

if [[ -e "$OUT" ]]; then
  echo "$OUT already exists. Edit it directly, or remove it first."
  exit 0
fi

echo "Enter soft-disclosure terms (employers, work email domains, internal"
echo "hostnames, project codenames, etc.), one per line. Empty line to finish."
terms=()
while IFS= read -r -p "> " line; do
  [[ -z "$line" ]] && break
  terms+=("$line")
done

if (( ${#terms[@]} == 0 )); then
  echo "No terms supplied; nothing written."
  exit 0
fi

{
  echo 'title = "local extra rules — not committed (see .gitignore)"'
  echo
  echo '[extend]'
  echo 'path = ".gitleaks.toml"'
  echo
  echo '# Auto-generated by scripts/setup-gitleaks-local. Safe to hand-edit.'
  for t in "${terms[@]}"; do
    # Lowercase, alphanumeric-only slug for the rule id.
    slug="$(printf '%s' "$t" | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9' '-' | sed 's/--*/-/g; s/^-//; s/-$//')"
    [[ -n "$slug" ]] || slug="term"
    # Escape regex metacharacters in the literal term.
    esc="$(printf '%s' "$t" | sed 's/[][\\.^$*+?(){}|]/\\&/g')"
    echo
    echo '[[rules]]'
    echo "id = \"local-$slug\""
    echo "description = \"Local soft-disclosure term — must not appear in this public repo.\""
    echo "regex = '''(?i)$esc'''"
  done
} > "$OUT"

chmod 600 "$OUT"
echo "Wrote $OUT (chmod 600). ${#terms[@]} rule(s) added."
echo
echo "Sanity check — pre-commit hook should now reject these terms:"
for t in "${terms[@]}"; do
  echo "  - $t"
done
