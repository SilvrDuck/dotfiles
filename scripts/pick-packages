#!/usr/bin/env bash
# Interactive per-machine package picker.
#
# Surfaces the opt-in groups defined under `optional:` in
# .chezmoidata/packages.yaml and records a yes/no per app in
# ~/.config/dotfiles/package-choices, which the package install reads at apply
# time to decide what to install on THIS machine. Choices are local and never
# synced. Re-run any time to revise; the shell login notice nags when a newly
# added optional app has not been answered on this machine yet.
#
# Usage:
#   scripts/pick-packages             choose, then `chezmoi apply` to realize it
#   scripts/pick-packages --no-apply  write choices only (the first-run bootstrap
#                                     uses this, as it is already mid-apply)
set -u

choices_file="$HOME/.config/dotfiles/package-choices"
apply=1
[ "${1:-}" = "--no-apply" ] && apply=0

# Catalogue: one "key|Label|m1,m2,..." line per optional group with at least one
# member valid on this OS. The bootstrap bakes it into PICK_CATALOGUE to avoid a
# nested chezmoi call mid-apply; a manual run renders it on demand.
catalogue="${PICK_CATALOGUE:-}"
if [ -z "$catalogue" ]; then
  catalogue="$(chezmoi execute-template '{{ template "optional-catalogue.tmpl" . }}' 2>/dev/null)"
fi
if [ -z "$catalogue" ]; then
  echo "pick-packages: no optional groups found (is the chezmoi source intact?)" >&2
  exit 1
fi

# >3 groups: gate each group with yes/no, then offer all-or-pick. <=3: ask per app.
group_count="$(printf '%s\n' "$catalogue" | grep -c '|')"

prev() {  # recorded state of an id: prints 1, 0, or nothing
  if grep -qxF "$1=1" "$choices_file" 2>/dev/null; then echo 1
  elif grep -qxF "$1=0" "$choices_file" 2>/dev/null; then echo 0
  fi
}

defof() {  # prompt default: the previous answer, else 0 (opt-in)
  local p; p="$(prev "$1")"
  [ -n "$p" ] && echo "$p" || echo 0
}

ask_yn() {  # "<prompt>" <default 0|1>  ->  prints 0 or 1
  local prompt="$1" def="$2" hint ans
  case "$def" in 1) hint="[Y/n]";; *) hint="[y/N]";; esac
  while :; do
    printf '%s %s ' "$prompt" "$hint" >/dev/tty
    IFS= read -r ans </dev/tty || ans=""
    [ -z "$ans" ] && ans="$def"
    case "$ans" in
      [Yy]*|1) echo 1; return;;
      [Nn]*|0) echo 0; return;;
    esac
  done
}

tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT
record() { printf '%s=%s\n' "$1" "$2" >>"$tmp"; }

printf '\nChoose which optional apps to install on this machine.\n' >/dev/tty
printf '(Baseline tools always install and are not shown.)\n' >/dev/tty

# The catalogue feeds the loop on stdin; every user prompt reads from /dev/tty,
# and answers are appended to $tmp (the loop runs in a subshell, so a file is
# how its work survives).
printf '%s\n' "$catalogue" | while IFS='|' read -r key label members; do
  [ -z "$key" ] && continue
  members="$(printf '%s' "$members" | tr ',' ' ')"

  if [ "$group_count" -gt 3 ]; then
    printf '\n' >/dev/tty
    gdef=0
    for m in $members; do [ "$(prev "$m")" = 1 ] && gdef=1; done
    if [ "$(ask_yn "$label?" "$gdef")" = 0 ]; then
      for m in $members; do record "$m" 0; done
      continue
    fi
    printf 'All of "%s", or pick individually? [A/p] ' "$label" >/dev/tty
    IFS= read -r mode </dev/tty || mode=""
    case "$mode" in
      [Pp]*) for m in $members; do record "$m" "$(ask_yn "  $m?" "$(defof "$m")")"; done;;
      *)     for m in $members; do record "$m" 1; done;;
    esac
  else
    printf '\n%s:\n' "$label" >/dev/tty
    for m in $members; do record "$m" "$(ask_yn "  $m?" "$(defof "$m")")"; done
  fi
done

mkdir -p "$(dirname "$choices_file")"
{
  echo "# Written by scripts/pick-packages -- <id>=1 (install) / <id>=0 (skip)"
  echo "# per optional package. Re-run the picker to change; do not hand-edit."
  sort "$tmp"
} >"$choices_file"
chmod 600 "$choices_file"

count="$(grep -c '=1$' "$choices_file" 2>/dev/null || true)"
printf '\nSaved %s opted-in app(s) to %s\n' "${count:-0}" "$choices_file" >/dev/tty

if [ "$apply" -eq 1 ]; then
  printf 'Applying with chezmoi...\n' >/dev/tty
  chezmoi apply
fi
