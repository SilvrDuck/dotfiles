#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  cat <<'HELP'
setup-interactive-logins

Per-machine post-install for tools that need a browser OAuth or
similar manual step that can't be baked into the chezmoi bootstrap.

Currently handles:
  Context7 MCP    — `npx ctx7 setup`   (Claude Code + OpenCode)
  Graphify        — `graphify install` (Claude Code + OpenCode)
  Browser MCP     — Playwright + Chrome DevTools (Claude Code + OpenCode, user scope)
HELP
  exit 0
fi

ask_run() {
  local name="$1"; shift
  local ans
  read -r -p "Set up $name? [y/N] " ans
  [[ "$ans" =~ ^[Yy]([Ee][Ss])?$ ]] || return 0
  "$@"
}

setup_context7() {
  if ! command -v npx >/dev/null 2>&1; then
    echo "npx not found. Install Node first (e.g. \`mise install node\`)." >&2
    return 1
  fi
  npx ctx7 setup
}

setup_graphify() {
  if ! command -v uv >/dev/null 2>&1; then
    echo "uv not found. Install uv first (e.g. \`curl -LsSf https://astral.sh/uv/install.sh | sh\`)." >&2
    return 1
  fi
  uv tool install --upgrade graphifyy
  command -v claude   >/dev/null 2>&1 && graphify install                       || true
  command -v opencode >/dev/null 2>&1 && graphify install --platform opencode   || true
}

setup_browser_mcp() {
  # User-scope MCP servers so every project on this machine sees them.
  # `|| true` keeps re-runs (duplicate-add errors) from aborting the rest.
  if command -v claude >/dev/null 2>&1; then
    claude mcp add --transport stdio --scope user playwright      -- npx -y @playwright/mcp@latest     || true
    claude mcp add --transport stdio --scope user chrome-devtools -- npx -y chrome-devtools-mcp@latest || true
  fi
  if command -v opencode >/dev/null 2>&1; then
    local cfg="${XDG_CONFIG_HOME:-$HOME/.config}/opencode/opencode.json"
    [ -f "$cfg" ] || printf '{"$schema":"https://opencode.ai/config.json"}\n' >"$cfg"
    local tmp; tmp="$(mktemp)"
    jq '.mcp.playwright         = {"type":"local","command":["npx","-y","@playwright/mcp@latest"],"enabled":true}
        | .mcp."chrome-devtools" = {"type":"local","command":["npx","-y","chrome-devtools-mcp@latest"],"enabled":true}' \
       "$cfg" >"$tmp" && mv "$tmp" "$cfg"
  fi
}

ask_run "Context7 MCP (Claude Code + OpenCode)"               setup_context7
ask_run "Graphify (Claude Code + OpenCode)"                   setup_graphify
ask_run "Browser MCP — Playwright + Chrome DevTools"          setup_browser_mcp

echo "Done."
