#!/usr/bin/env bash
# Background sync for the Obsidian vault. Triggered by launchd (macOS) or
# systemd user timer (Linux); also safe to run manually.
# SSH auth relies on `git config core.sshCommand` in the vault repo pointing
# at a per-machine deploy key, set up once by scripts/setup-obsidian-vault.

set -uo pipefail

VAULT="${VAULT_DIR:-$HOME/vaults/main}"
LOCK="${TMPDIR:-/tmp}/vault-sync.lock"

ts() { date -u +%Y-%m-%dT%H:%M:%SZ; }

# mkdir-based lock with PID-in-dir stale recovery (portable, no flock dep).
if ! mkdir "$LOCK" 2>/dev/null; then
  if [ -f "$LOCK/pid" ] && ! kill -0 "$(cat "$LOCK/pid")" 2>/dev/null; then
    rm -rf "$LOCK"
    mkdir "$LOCK" 2>/dev/null || exit 0
  else
    exit 0
  fi
fi
echo $$ > "$LOCK/pid"
trap 'rm -rf "$LOCK"' EXIT INT TERM

[ -d "$VAULT/.git" ] || { echo "[$(ts)] no vault at $VAULT, skipping" >&2; exit 0; }
cd "$VAULT" || exit 1

if ! git diff --quiet || ! git diff --cached --quiet; then
  git add -A
  git -c user.name="vault-sync" -c user.email="vault-sync@local" \
      commit -m "vault-sync $(ts)" >/dev/null
fi

git pull --rebase --autostash --quiet || { echo "[$(ts)] pull failed" >&2; exit 1; }
git push --quiet                       || { echo "[$(ts)] push failed" >&2; exit 1; }
echo "[$(ts)] ok"
