#!/usr/bin/env bash
# (Re)loads the Bluetooth-off-on-sleep LaunchAgent (sleepwatcher driving
# ~/.local/bin/bt-sleep). run_onchange so a changed plist or helper rebootstraps
# the running agent. macOS-only; off macOS the plist is not even applied
# (.chezmoiignore), so this is a no-op. sleepwatcher is baseline on Mac, but
# install is best-effort, so guard on the binary anyway — a plist pointing at a
# missing binary would just respawn-fail under KeepAlive.
#
# plist hash:  {{ include "Library/LaunchAgents/com.dotfiles.bluetooth-sleep.plist.tmpl" | sha256sum }}
# helper hash: {{ include "dot_local/bin/executable_bt-sleep" | sha256sum }}
{{ if .is_mac -}}
set -euo pipefail

label="com.dotfiles.bluetooth-sleep"
plist="$HOME/Library/LaunchAgents/${label}.plist"
domain="gui/$(id -u)"

# Log dir must exist before launchd opens the StandardOutPath.
mkdir -p "$HOME/.local/state/bluetooth-sleep"

# bootout first so a changed plist reloads cleanly; tolerates "not loaded yet".
launchctl bootout "$domain/$label" 2>/dev/null || true

# Only (re)bootstrap when sleepwatcher is actually present. If its install was
# skipped or failed the binary is absent, so leave the agent torn down.
if command -v sleepwatcher >/dev/null 2>&1 \
  || [ -x /opt/homebrew/sbin/sleepwatcher ] \
  || [ -x /usr/local/sbin/sleepwatcher ]; then
  launchctl bootstrap "$domain" "$plist" 2>/dev/null || true
  launchctl enable "$domain/$label" 2>/dev/null || true
fi
{{ end -}}
exit 0
