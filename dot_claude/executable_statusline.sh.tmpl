#!/usr/bin/env bash
#
# Claude Code status line:
#   <model> (<effort>) · <session>
# where <session> follows what the account reports. With usage-window
# percentages, the slice of the 5-hour window this session accounts for
# (the 5h figure scaled by the session's cost share of the active block),
# then the 5h / 7d window figures; with a monthly budget set for this machine, the
# session cost plus a month-to-date estimate against that budget; otherwise
# the session cost alone.
#
# Spend figures are estimates: ccusage sums this machine's local transcripts
# at public list pricing, so they will not reflect other machines, other
# clients, or account-specific rates. They are refreshed by detached,
# throttled background jobs and read from cache, so rendering never blocks.
# Set claude_monthly_spend_limit in the per-machine chezmoi [data] to enable
# the month display; unset (0) leaves it off. claude_month_cost_factor
# (default 1.0) scales the month estimate to reconcile it with an
# authoritative figure when the two differ; adjust as needed.

set -uo pipefail

LIMIT={{ index . "claude_monthly_spend_limit" | default 0 }}
FACTOR={{ index . "claude_month_cost_factor" | default 1.0 }}
CACHE_DIR="${HOME}/.cache/dotfiles"
CACHE_MONTH="${CACHE_DIR}/claude-month-cost"
CACHE_5H="${CACHE_DIR}/claude-5h-cost"
TTL_MIN=10

stale() {
  [ -z "$(find "$1" -mmin -"$TTL_MIN" 2>/dev/null)" ]
}

read_cache() {
  [ -f "$1" ] && cat "$1" 2>/dev/null || printf ''
}

refresh_cache() {
  local cache="$1" filter="$2"
  shift 2
  local -a runner
  if command -v ccusage >/dev/null 2>&1; then
    runner=(ccusage)
  elif command -v bunx >/dev/null 2>&1; then
    runner=(bunx ccusage)
  else
    runner=(npx -y ccusage)
  fi
  local val
  val=$("${runner[@]}" "$@" --json --offline 2>/dev/null | jq -r "$filter" 2>/dev/null)
  [ -n "$val" ] || val=0
  mkdir -p "$(dirname "$cache")"
  printf '%s' "$val" > "$cache"
}

payload=$(cat)

IFS=$'\x1f' read -r model effort session rl fh < <(
  printf '%s' "$payload" | jq -r '
    [ (.model.display_name // "?")
    , (.effort.level // "")
    , ((.cost.total_cost_usd // 0) | tostring)
    , (if .rate_limits then "1" else "0" end)
    , ((.rate_limits.five_hour.used_percentage // "") | tostring)
    ] | join("\u001f")'
)

modelpart="$model"
[ -n "$effort" ] && modelpart="$modelpart ($effort)"
line="$modelpart"

if [ "$rl" = "1" ]; then
  block=$(read_cache "$CACHE_5H")
  if stale "$CACHE_5H"; then
    refresh_cache "$CACHE_5H" \
      '[.blocks[]? | select(.isActive) | .costUSD] | add // 0' \
      blocks --active >/dev/null 2>&1 </dev/null &
    disown 2>/dev/null || true
  fi
  share=$(awk -v s="$session" -v b="$block" -v fh="$fh" \
    'BEGIN {
       if (fh == "" || b <= 0) { printf "?%%"; exit }
       v = fh * s / b; if (v > fh) v = fh
       printf "%.0f%%", v
     }')
  line="$line · $share"
  line="$line$(printf '%s' "$payload" | jq -r '
    def p($x): if $x == null then "?" else ($x | round | tostring) end;
    " · 5h \(p(.rate_limits.five_hour.used_percentage))% · 7d \(p(.rate_limits.seven_day.used_percentage))%"')"
elif [ "$LIMIT" != "0" ]; then
  line=$(printf '%s · $%.2f' "$line" "$session")
  spent=$(read_cache "$CACHE_MONTH")
  if stale "$CACHE_MONTH"; then
    refresh_cache "$CACHE_MONTH" \
      '(.totals.totalCost) // ((.monthly // .) | if type == "array" then (map(.totalCost) | add) else .totalCost end) // 0' \
      monthly --since "$(date +%Y%m01)" >/dev/null 2>&1 </dev/null &
    disown 2>/dev/null || true
  fi
  if [ -n "$spent" ]; then
    line=$(awk -v m="$line" -v s="$spent" -v l="$LIMIT" -v f="$FACTOR" \
      'BEGIN { c = s * f; printf "%s · ~$%.0f/$%.0f mo (%.0f%%)", m, c, l, (l > 0 ? c / l * 100 : 0) }')
  else
    line=$(awk -v m="$line" -v l="$LIMIT" 'BEGIN { printf "%s · ~$?/$%.0f mo", m, l }')
  fi
else
  line=$(printf '%s · $%.2f' "$line" "$session")
fi

printf '%s' "$line"
