#!/usr/bin/env bash
#
# Claude Code status line:
#   <model> (<effort>) · $<session cost>
# then, when usage-window percentages are reported, the 5h / 7d figures;
# otherwise, when a monthly budget is set for this machine, a month-to-date
# cost estimate against that budget.
#
# The month figure is an estimate: ccusage sums this machine's local
# transcripts at public list pricing, so it will not reflect other machines,
# other clients, or account-specific rates. It is refreshed by a detached,
# throttled background job and read from cache, so rendering never blocks.
# Set claude_monthly_spend_limit in the per-machine chezmoi [data] to enable
# it; unset (0) leaves the month display off. claude_month_cost_factor
# (default 1.0) scales the estimate to reconcile it with an authoritative
# figure when the two differ; adjust as needed.

set -uo pipefail

LIMIT={{ index . "claude_monthly_spend_limit" | default 0 }}
FACTOR={{ index . "claude_month_cost_factor" | default 1.0 }}
CACHE="${HOME}/.cache/dotfiles/claude-month-cost"
TTL_MIN=10

refresh_month_cost() {
  local start cost
  start=$(date +%Y%m01)
  if command -v ccusage >/dev/null 2>&1; then
    set -- ccusage
  elif command -v bunx >/dev/null 2>&1; then
    set -- bunx ccusage
  else
    set -- npx -y ccusage
  fi
  cost=$("$@" monthly --since "$start" --json --offline 2>/dev/null \
    | jq -r '(.totals.totalCost)
             // ((.monthly // .)
                 | if type == "array" then (map(.totalCost) | add) else .totalCost end)
             // 0' 2>/dev/null)
  [ -n "$cost" ] || cost=0
  mkdir -p "$(dirname "$CACHE")"
  printf '%s' "$cost" > "$CACHE"
}

payload=$(cat)

IFS=$'\x1f' read -r model effort session rl < <(
  printf '%s' "$payload" | jq -r '
    [ (.model.display_name // "?")
    , (.effort.level // "")
    , ((.cost.total_cost_usd // 0) | tostring)
    , (if .rate_limits then "1" else "0" end)
    ] | join("\u001f")'
)

modelpart="$model"
[ -n "$effort" ] && modelpart="$modelpart ($effort)"
line=$(printf '%s · $%.2f' "$modelpart" "$session")

if [ "$rl" = "1" ]; then
  line="$line$(printf '%s' "$payload" | jq -r '
    def p($x): if $x == null then "?" else ($x | round | tostring) end;
    " · 5h \(p(.rate_limits.five_hour.used_percentage))% · 7d \(p(.rate_limits.seven_day.used_percentage))%"')"
elif [ "$LIMIT" != "0" ]; then
  spent=""
  [ -f "$CACHE" ] && spent=$(cat "$CACHE" 2>/dev/null)
  if [ -z "$(find "$CACHE" -mmin -"$TTL_MIN" 2>/dev/null)" ]; then
    refresh_month_cost >/dev/null 2>&1 </dev/null &
    disown 2>/dev/null || true
  fi
  if [ -n "$spent" ]; then
    line=$(awk -v m="$line" -v s="$spent" -v l="$LIMIT" -v f="$FACTOR" \
      'BEGIN { c = s * f; printf "%s · ~$%.0f/$%.0f mo (%.0f%%)", m, c, l, (l > 0 ? c / l * 100 : 0) }')
  else
    line=$(awk -v m="$line" -v l="$LIMIT" 'BEGIN { printf "%s · ~$?/$%.0f mo", m, l }')
  fi
fi

printf '%s' "$line"
