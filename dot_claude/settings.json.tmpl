{{- /*
  PUBLIC REPO — this file is committed to a public chezmoi-dotfiles repo.
  Promote entries here only after a full audit: no employer references,
  no internal hostnames, no soft-disclosure of tooling tied to work identity.
  Machine-local + work-tagged settings live in ~/.claude/settings.local.json
  (untracked). See CLAUDE.md "public-internet audit" rules and .gitleaks.toml.

  Private plugins / marketplaces (work, client, employer, internal codenames):
  declare in ~/.config/chezmoi/chezmoi.toml — local, untracked, NEVER in this repo.

      [data.private_marketplaces.<marketplace-name>]
      repo = "<owner>/<repo>"

      [data.private_plugins]
      "<plugin>@<marketplace-name>" = true

  The range loops below inline these into the single enabledPlugins /
  extraKnownMarketplaces blocks, sidestepping Claude Code's shallow-merge of
  settings.json over settings.local.json for these two keys.
*/ -}}
{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Read(~/.claude/host-notes.md)",
      "Edit(~/.claude/host-notes.md)",
      "Write(~/.claude/host-notes.md)"
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "telegram@claude-plugins-official": true{{ range $name, $on := (.private_plugins | default dict) }},
    {{ $name | quote }}: {{ $on }}{{ end }}
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }{{ range $name, $cfg := (.private_marketplaces | default dict) }},
    {{ $name | quote }}: {
      "source": {
        "source": "github",
        "repo": {{ $cfg.repo | quote }}
      }
    }{{ end }}
  },
  "theme": "dark",
  "skipAutoPermissionPrompt": true,
  "effortLevel": "xhigh"
}
